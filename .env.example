# Auth
HASHED_PASSWORD=       # bcrypt hash — generate with: node -e "import('bcrypt').then(m=>m.default.hash('YourPassword',12)).then(console.log)"
JWT_SECRET=            # long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

